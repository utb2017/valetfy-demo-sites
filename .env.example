# Dev Firebase (valetfy-main-dev) — copy from valetfy .env.dev-preview
FIREBASE_ADMIN_PROJECT_ID=valetfy-main-dev
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY_BASE64=

# Client Firebase Auth (Valetfy SSO)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=valetfy-main-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=valetfy-main-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe TEST only (sk_test_ / pk_test_)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_DEMO_SITES_PRODUCT_ID=
STRIPE_DEMO_SITES_PRICE_ID=
STRIPE_DEMO_SITES_WEBHOOK_SECRET=
DEMO_SITES_CLAIM_PRICE_USD=19

# Host parsing
DEMO_SITES_BASE_DOMAIN=dev.sites.valetfy.com
DEMO_SITES_SITE_ORIGIN=
DEMO_SITES_DEV_SLUG=scott

# Vercel custom domain attach (optional)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# Webhook registration script override
DEMO_SITES_WEBHOOK_URL=https://valetfy-demo-sites.vercel.app/api/stripe/webhook
