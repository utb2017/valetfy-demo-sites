# Dev Firebase (valetfy-main-dev) — copy from valetfy .env.dev-preview
FIREBASE_ADMIN_PROJECT_ID=valetfy-main-dev
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY_BASE64=

# Optional: future client-side Valetfy SSO
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=valetfy-main-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=valetfy-main-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Host parsing (default matches dev wildcard)
DEMO_SITES_BASE_DOMAIN=dev.sites.valetfy.com

# Local dev fallback when Host header has no subdomain
DEMO_SITES_DEV_SLUG=scott
